,{"path":["schema:contributor"],"description":"Other parties who contributed to the resource.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:publisher"],"description":"Party that made the resource publicly available.","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:editor"],"description":"Editors of the resource.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:funding"],"description":"Funding sources and grants that supported the resource.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:funding","schema:identifier"],"description":"identifier for a particular grant","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.funder"]},{"path":["schema:funding","schema:description"],"description":"description of the funding or grant","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.funder"]},{"path":["schema:funding","schema:name"],"description":"title of the grant","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.funder"]},{"path":["schema:funding","schema:funder"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.funder"]},{"path":["schema:keywords"],"description":"Free-text keywords describing the resource content.","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:about"],"description":"Science domains that the resource addresses. Array of DefinedTerm objects referencing the ECRR ADO (Academic Discipline Ontology) vocabulary.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:about","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:about","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:about","schema:inDefinedTermSet"],"description":"Identifier for the controlled vocabulary responsible for this keyword.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:about","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary (Optional).  Analogous to skos:Notation","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:audience"],"description":"Target user communities for the resource. Array of Audience objects with audienceType labels and identifiers from the AUT vocabulary.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:audience","schema:audienceType"],"description":"Label for the target audience (e.g. Data Producers, Scientists, Developers). Values from ECRR AUT vocabulary.","required":true,"schema_type":"string","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:audience","schema:identifier"],"description":"URI from the ECRR AUT_ vocabulary.","schema_type":"string","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:subjectOf"],"description":"Links to formal metadata records or web pages about this resource. Array of labeled links (CreativeWork objects with name and url).","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:isRelatedTo"],"description":"Related resources such as documentation, publications, or tools. Array of labeled links.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:isBasedOn"],"description":"Resources (e.g. semantic resources, specifications) that this resource is based on or derived from. Array of labeled links.","schema_t