liation","schema:additionalType","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:creator","_anyOf","1","schema:affiliation","schema:additionalType","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:subjectOf","schema:url"],"required":true,"schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:subjectOf","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]},{"path":["schema:subjectOf","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.labeledLink"]}]}