{"defs":{},"properties":[{"path":["schema:identifier"],"description":"External identifier for the resource (e.g. DOI, ARK). Use PropertyValue pattern to specify identifier scheme and resolver URL.","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:url"],"description":"URL of a landing page or web resource describing the resource.","schema_type":"string","format":"uri","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:datePublished"],"description":"ISO 8601 formatted date when the resource was published or released.","schema_type":"string","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:version"],"description":"Version number or identifier for this resource.","schema_type":["string","number"],"sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:alternateName"],"description":"Alternative names by which the resource is known.","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:sameAs"],"description":"Other identifiers or URIs for the same resource.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:creator"],"description":"Authors or originators of the resource content. Array of Person or Organization objects. Use @list wrapper to preserve author order in JSON-LD.","schema_type":"array","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"]},{"path":["schema:creator","_anyOf"],"sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"],"keyword":"anyOf"},{"path":["schema:creator","_anyOf","1"],"title":"a","sources":["bblocks://ecrr.bbr.metadata.ecrrProperties.ecrrCommon"],"keyword":"branch"},{"path":["schema:creator","_anyOf","1","schema:name"],"description":"string label for person that is meaningful for human users","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path"