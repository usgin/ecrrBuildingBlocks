{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "title": "ECRR Service Instance Profile",
    "description": "Complete ECRR metadata profile for service instance resources. Composes ecrrCore, ecrrCommon, ecrrAssessment, and ecrrService. Resources must have schema:additionalType containing \"EC Service Instance\".",
    "allOf": [
        {
            "$ref": "../../../ecrrProperties/ecrrCore/ecrrCoreSchema.json"
        },
        {
            "$ref": "../../../ecrrProperties/ecrrCommon/ecrrCommonSchema.json"
        },
        {
            "$ref": "../../../ecrrProperties/ecrrAssessment/ecrrAssessmentSchema.json"
        },
        {
            "$ref": "../../../ecrrProperties/ecrrService/ecrrServiceSchema.json"
        },
        {
            "properties": {
                "schema:additionalType": {
                    "contains": {
                        "enum": [
                            "EC Service Instance"
                        ]
                    }
                }
            }
        }
    ]
}
